# 数据库配置
DB_USERNAME=YOUR_DB_USERNAME
DB_PASSWORD=YOUR_DB_PASSWORD
DB_HOST=YOUR_DB_HOST
DB_PORT=YOUR_DB_PORT
DB_NAME=YOUR_DB_NAME

# LangSmith（LangChain 追踪，配置在项目根目录 .env）
# 在 https://smith.langchain.com/ 创建 API Key 后填入下方三项
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_pt_你的密钥
LANGCHAIN_PROJECT=ai-recruitment-system

# LangGraph checkpoint 严格模式（可选，默认 false）
# 设为 true 时，未在白名单中的类型将无法反序列化；白名单见 agents/candidate.py
# LANGGRAPH_STRICT_MSGPACK=false

# deepseek
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY
DEEPSEEK_API_BASE=YOUR_DEEPSEEK_API_BASE

## openai
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_BASE_URL=YOUR_OPENAI_BASE_URL